}
QLabel {
    font-size: 14px;
    color: #374151;
}

/* ----- CAMPOS INPUT ----- */
QLineEdit {
    background: #ffffff;
    border-radius: 10px;
    border: 1px solid #cbd5e1;
    padding: 8px 10px;
}
QLineEdit:focus {
    border: 2px solid #4f46e5;
}

/* ----- BOTÕES ----- */
QPushButton {
    border-radius: 10px;
    padding: 10px;
    font-size: 14px;
    font-weight: 700;
}

/* Botão principal */
QPushButton#btnEntrar {
    background-color: #4f46e5;
    color: white;
}
QPushButton#btnEntrar:hover {
    background-color: #4338ca;
}
QPushButton#btnEntrar:pressed {
    background-color: #372fbd;
}
