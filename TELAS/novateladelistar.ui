/* ============================
   ESTILO GERAL
============================ */
QWidget {
    background: #f3f4f6;
    font-family: &quot;Segoe UI&quot;, Arial;
    color: #1f2937;
    font-size: 14px;
}

/* ============================
   TÍTULO DA PÁGINA
============================ */
QLabel#tituloPagina {
    font-size: 26px;
    font-weight: 700;
    color: #111827;
    padding: 6px 4px 12px 4px;
}

/* ============================
   CARD PRINCIPAL DA TABELA
============================ */
QFrame#cardTabela {
    background: #ffffff;
    border-radius: 14px;
    border: 1px solid #e5e7eb;
    padding: 14px;
}

/* ============================
   TABELA
============================ */
QTableWidget {
    background: #ffffff;
    border-radius: 12px;
    border: 1px solid #d1d5db;
    gridline-color: #e5e7eb;
    selection-background-color: #4f46e5;
    selection-color: white;
    alternate-background-color: #f9fafb;
}

QHeaderView::section {
    background: #f1f5f9;
    color: #1f2937;
    padding: 10px;
    border: none;
    font-weight: bold;
    font-size: 14px;
}

QTableWidget::item:hover {
    background: #e0e7ff;
    color: #1e1b4b;
}

/* ============================
   BOTÕES
============================ */
QPushButton {
    padding: 10px 18px;
    border-radius: 10px;
    font-weight: 600;
    border: none;
}

QPushButton#btnModificar {
    background-color: #2563eb;
    color: white;
}
QPushButton#btnModificar:hover { background-color: #1d4ed8; }
QPushButton#btnModificar:pressed { background-color: #1e40af; }

QPushButton#btnExcluir {
    background-color: #dc2626;
    color: white;
}
QPushButton#btnExcluir:hover { background-color: #b91c1c; }
QPushButton#btnExcluir:pressed { background-color: #991b1b; }

QPushButton#btnSalvar {
    background-color: #16a34a;
    color: white;
}
QPushButton#btnSalvar:hover { background-color: #15803d; }
QPushButton#btnSalvar:pressed { background-color: #166534; }
